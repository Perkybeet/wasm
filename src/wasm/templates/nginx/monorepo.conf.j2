# Nginx configuration for {{ domain }} (Monorepo)
# Generated by WASM

# Upstream backends for each workspace
{% for workspace in workspaces %}
upstream {{ workspace.name | replace("-", "_") }}_backend {
    server 127.0.0.1:{{ workspace.port }};
}
{% endfor %}

# HTTP server for ACME challenges and redirects
server {
    listen 80;
    listen [::]:80;
    server_name {{ domain }} {% for ws in workspaces %}{{ ws.subdomain }}.{{ domain }} {% endfor %};

    # ACME challenge location for Let's Encrypt
    location /.well-known/acme-challenge/ {
        root /var/www/html;
        allow all;
    }

{% if ssl %}
    # Redirect HTTP to HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

# Main domain redirect to primary web app
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ domain }};

    ssl_certificate /etc/letsencrypt/live/{{ domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    # Redirect to primary subdomain
    return 301 https://{{ primary_subdomain }}.{{ domain }}$request_uri;
}

# HTTPS server for each workspace
{% for workspace in workspaces %}
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ workspace.subdomain }}.{{ domain }};

    # SSL Configuration
    ssl_certificate /etc/letsencrypt/live/{{ domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem;

    # SSL Settings
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;

    # Logging
    access_log /var/log/nginx/{{ workspace.subdomain }}.{{ domain }}.access.log;
    error_log /var/log/nginx/{{ workspace.subdomain }}.{{ domain }}.error.log;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/xml application/json application/javascript application/rss+xml application/atom+xml image/svg+xml;

    # Proxy to backend
    location / {
        proxy_pass http://{{ workspace.name | replace("-", "_") }}_backend;
        proxy_http_version 1.1;

        # Headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        # WebSocket support
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        # Buffer settings
        proxy_buffering on;
        proxy_buffer_size 128k;
        proxy_buffers 4 256k;
        proxy_busy_buffers_size 256k;
    }
}

{% endfor %}
{% else %}
    # HTTP-only configuration (no SSL)
    # Route based on Host header
{% for workspace in workspaces %}
    # {{ workspace.name }} on {{ workspace.subdomain }}.{{ domain }}
    set $backend_{{ workspace.name | replace("-", "_") }} 0;
    if ($host = "{{ workspace.subdomain }}.{{ domain }}") {
        set $backend_{{ workspace.name | replace("-", "_") }} 1;
    }
{% endfor %}

{% for workspace in workspaces %}
    location @{{ workspace.name | replace("-", "_") }} {
        proxy_pass http://{{ workspace.name | replace("-", "_") }}_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

{% endfor %}
    location / {
{% for workspace in workspaces %}
        if ($host = "{{ workspace.subdomain }}.{{ domain }}") {
            proxy_pass http://{{ workspace.name | replace("-", "_") }}_backend;
        }
{% endfor %}
    }
}
{% endif %}
