# Advanced Nginx configuration for {{ domain }}
# Generated by WASM - Multi-route reverse proxy

{% for zone_name, rate in rate_limit_zones.items() %}
limit_req_zone $binary_remote_addr zone={{ zone_name }}:10m rate={{ rate }};
{% endfor %}

{% for name, upstream in upstreams.items() %}
upstream {{ upstream.name }} {
    server 127.0.0.1:{{ upstream.port }};
}
{% endfor %}

server {
    listen 80;
    listen [::]:80;
    server_name {{ domain }};

    # ACME challenge location for Let's Encrypt (webroot method)
    location /.well-known/acme-challenge/ {
        root /var/www/html;
        allow all;
    }

{% if ssl %}
    # Redirect HTTP to HTTPS (except ACME challenges)
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ domain }};

    # SSL Configuration
    ssl_certificate {{ ssl_certificate }};
    ssl_certificate_key {{ ssl_certificate_key }};

    # SSL Settings
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;
    ssl_stapling on;
    ssl_stapling_verify on;
{% endif %}

    # Logging
    access_log /var/log/nginx/{{ domain }}.access.log;
    error_log /var/log/nginx/{{ domain }}.error.log;

    # Security headers
{% for header, value in security_headers.items() %}
    add_header {{ header }} "{{ value }}" always;
{% endfor %}

    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/xml application/json application/javascript application/rss+xml application/atom+xml image/svg+xml;

{% for directive in custom_directives %}
    {{ directive }};
{% endfor %}

{% for route in routes %}
    # Route: {{ route.path }} -> {{ route.upstream_name }}:{{ route.upstream_port }}
    location {{ route.path }} {
{% if route.rate_limit %}
        limit_req zone={{ route.rate_limit_zone }} burst={{ route.rate_limit_burst }} nodelay;
{% endif %}
{% if route.strip_prefix and route.path != '/' %}
        rewrite ^{{ route.path }}(.*)$ /$1 break;
{% endif %}
        proxy_pass http://{{ route.upstream_name }};
        proxy_http_version 1.1;

        # Headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

{% if route.websocket %}
        # WebSocket support
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
{% endif %}

        # Timeouts
        proxy_connect_timeout {{ route.timeout }}s;
        proxy_send_timeout {{ route.timeout }}s;
        proxy_read_timeout {{ route.timeout }}s;

{% if route.buffer_size %}
        # Custom buffer settings
        proxy_buffer_size {{ route.buffer_size }};
        proxy_buffers 4 {{ route.buffer_size }};
        proxy_busy_buffers_size {{ route.buffer_size }};
{% else %}
        # Buffer settings
        proxy_buffering on;
        proxy_buffer_size 128k;
        proxy_buffers 4 256k;
        proxy_busy_buffers_size 256k;
{% endif %}
    }

{% endfor %}
}
